---
import global from "../data/banner.json" with { type: "json" };
let { banner } = Astro.locals.starlightRoute.entry.data;

// no banner on page
if (!banner) {
  // check the global banner
  if (global.content) {
    banner = global;
  }
}
---

{
  banner && (
    <div class="sl-banner" data-pagefind-ignore set:html={banner.content} />
  )
}

{banner && (
  <script>
    function initBanner() {
      const banner = document.querySelector('.sl-banner');
      if (!banner) return;
      // Move banner to the top of <body>
      document.body.prepend(banner);
      // Set CSS variable for offset
      function update() {
        document.documentElement.style.setProperty('--sl-banner-height', banner.offsetHeight + 'px');
      }
      update();
      window.addEventListener('resize', update);
    }
    initBanner();
    document.addEventListener('astro:after-swap', initBanner);
  </script>
)}

<style>
  .sl-banner {
    --__sl-banner-text: var(
      --sl-color-banner-text,
      var(--sl-color-text-invert)
    );
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: calc(var(--sl-z-index-navbar) + 1);
    padding: 12px 24px;
    background-color: var(--sl-color-banner-bg, var(--sl-color-bg-accent));
    color: var(--__sl-banner-text);
    line-height: var(--sl-line-height-headings);
    text-align: center;
    text-wrap: balance;
    box-shadow: var(--sl-shadow-sm);
  }
  .sl-banner :global(a) {
    color: var(--__sl-banner-text);
  }
</style>

<style is:global>
  :root {
    --sl-banner-height: 0px;
  }
  header.header {
    top: var(--sl-banner-height) !important;
  }
  .sidebar-pane {
    top: calc(var(--sl-nav-height) + var(--sl-banner-height)) !important;
  }
  .main-frame {
    padding-top: calc(var(--sl-nav-height) + var(--sl-mobile-toc-height) + var(--sl-banner-height)) !important;
  }
  .right-sidebar {
    padding-top: calc(var(--sl-nav-height) + var(--sl-banner-height)) !important;
  }
</style>
